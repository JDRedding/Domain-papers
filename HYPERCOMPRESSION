def cluster_triadic_modes(exponents, invariants):

    clusters = cluster_by_relational_similarity(exponents, invariants)
    modes = []

    for C in clusters:

        MODE = {
            "prime_subset"       : choose_primes(C),
            "delta_scheme"       : choose_delta_scheme(C),
            "relational_operator": choose_operator(C),   # SID / PED / Q□
            "closure_invariant"  : detect_closure(C),
            "packing_method"     : choose_packing(C),
            "region"             : C.region
        }

        modes.append(MODE)

    return modes
