def qbox_pack(D, modes):

    stream = []

    for MODE in modes:

        region = MODE.region
        scheme = MODE.packing_method

        for (z,y,x) in region:

            sid   = D.sid[z][y][x]
            ped   = D.ped[z][y][x]
            qsig  = D.qbox[z][y][x]
            tri   = D.triad[z][y][x]

            qbox = encode_qbox(
                sid_delta=sid,
                ped_delta=ped,
                q_delta=qsig,
                tri_delta=tri,
                scheme=scheme
            )

            stream.append(qbox)

    return stream
